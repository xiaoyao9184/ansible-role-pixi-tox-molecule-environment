{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid": "830387
    "version": "0.2.0",
    "configurations": [
        {
            // Before running the program,
            // please be sure to select a Python interpreter named `core*` in pixi.
            "name": "molecule: scenario test",
            "type": "debugpy",
            "request": "launch",
            "module": "molecule",
            "args": [
                "--debug",
                "-vvv",
                "test",
                "--scenario-name",
                "${input:moleculeScenario}"
            ],
            "env": {
                // fix debugpy PATH
                "PATH": "${workspaceFolder}/.pixi/envs/${input:moleculeCore}/bin:${env:PATH}",
                "MOLECULE_GLOB": "${workspaceFolder}/molecule/${input:moleculeCore}/*/molecule.yml",
                "XDG_CACHE_HOME": "${workspaceFolder}/molecule/${input:moleculeCore}/.cache",
                "ANSIBLE_HOME": "${workspaceFolder}/molecule/${input:moleculeCore}/.ansible",
                "ANSIBLE_ROLES_PATH": "${workspaceFolder}/molecule/${input:moleculeCore}/.ansible/roles",
            },
            "preLaunchTask": "bash: molecule cache remove",
            "justMyCode": false
        },
        {
            // Before running the program,
            // please be sure to select a Python interpreter named `core*` in pixi.
            "name": "molecule: scenario list",
            "type": "debugpy",
            "request": "launch",
            "module": "molecule",
            "args": [
                "--debug",
                "-vvv",
                "list"
            ],
            "env": {
                // fix debugpy PATH
                "PATH": "${workspaceFolder}/.pixi/envs/${input:moleculeCore}/bin:${env:PATH}",
                "MOLECULE_GLOB": "${workspaceFolder}/molecule/${input:moleculeCore}/*/molecule.yml",
                "XDG_CACHE_HOME": "${workspaceFolder}/molecule/${input:moleculeCore}/.cache",
                "ANSIBLE_HOME": "${workspaceFolder}/molecule/${input:moleculeCore}/.ansible",
                "ANSIBLE_ROLES_PATH": "${workspaceFolder}/molecule/${input:moleculeCore}/.ansible/roles",
            },
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "moleculeCore",
            "type": "pickString",
            "description": "Select the Molecule core environment",
            "default": "core220",
            // Consistent with pixi environments and molecule/* directories
            "options": [
                "core29",
                "core210",
                "core211",
                "core212",
                "core213",
                "core214",
                "core215",
                "core216",
                "core217",
                "core218",
                "core219",
                "core220"
            ]
        },
        {
            "id": "moleculeScenario",
            "type": "pickString",
            "description": "Select the Molecule scenario",
            "default": "default",
            "options": [
                "default",
                "docker"
            ]
        }
    ]
}