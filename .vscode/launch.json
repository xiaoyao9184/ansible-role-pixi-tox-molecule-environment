        {
            "id": "moleculeCore",
            "type": "pickString",
            "description": "Select the Molecule core environment",
            "default": "core220",
            // Consistent with pixi environments and molecule/* directories
            "options": [
                "core29",
                "core210",
                "core211",
                "core212",
                "core213",
                "core214",
                "core215",
                "core216",
                "core217",
                "core218",
